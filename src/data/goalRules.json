        "sourceIds": ["sample-general-principles"],
        "confidence": "medium"
      },
      {
        "id": "baseline-balance",
        "tuningArea": "balance",
        "title": "建立防倾杆 / 空力 / 刹车的安全平衡",
        "purpose": "让车先可预测，再把具体推头或甩尾交给问诊模块处理。",
        "requiresCapabilities": ["tunable_antiroll_bars", "tunable_brakes"],
        "baselineAction": "防倾杆先保持前后不要极端；刹车先用稳定方向；如果有前后空力，避免只拉满后空力。",
        "safeRange": "每个项目先改一小格或小比例，测试后再决定是否继续。",
        "doNotOptimizeYet": ["不要为了高速稳定单独堆后空力", "不要为了入弯灵活把刹车过度后移"],
