        "requiresCapabilities": ["adjustable_gearing"],
        "knownFacts": ["adjustable_transmission_unlocks_gear_ratio_tuning"],
        "baselineAction": "用最长直线检查最高档是否过早顶转；如果频繁换挡，先略拉长终传。",
        "safeRange": "每次只小幅移动，优先保证可控和档位稳定。",
        "doNotOptimizeYet": ["不要一开始逐档追求极限加速", "不要同时改动力和齿比"],
        "handoffSymptoms": ["frequent_shifting", "too_slow_on_straights", "launch_wheelspin"],
        "sourceIds": ["sample-general-principles"],
