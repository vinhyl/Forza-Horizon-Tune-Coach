            "prompt": "游戏里这些抓地/刹车升级是否可安装？",
            "requiredWhen": ["availability_unknown"],
            "choices": [
              { "value": "yes", "label": "可以" },
              { "value": "partial", "label": "只能装一部分" },
              { "value": "no", "label": "不能装" }
            ]
          },
          {
            "key": "pi_delta",
            "prompt": "如果装完接近或超过目标等级，PI 变化大约是多少？",
            "requiredWhen": ["pi_budget_tight"]
          }
        ],
        "keepWhen": ["handling_or_braking_improves", "pi_delta_within_budget"],
        "skipWhen": ["pi_over_limit_and_no_core_symptom_improvement"],
        "fallbackParts": ["antiroll_bars", "suspension"],
        "handoffSymptoms": ["entry_understeer", "braking_instability", "launch_wheelspin"],
        "sourceIds": ["sample-general-principles"],
        "confidence": "medium"
      },
      {
