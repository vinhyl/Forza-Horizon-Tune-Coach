          { "symptomId": "exit_oversteer", "label": "出弯甩尾" },
          { "symptomId": "braking_instability", "label": "刹车时车尾不稳" }
        ]
      }
    ],
    "escalationRules": [
      {
        "when": ["clear_symptom_after_baseline_test"],
