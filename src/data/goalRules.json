    "firstTestPlan": [
      {
        "id": "baseline-road-test",
        "title": "第一次基线测试",
        "method": "选择同一段路线跑 2~3 次，只记录最大问题发生在入弯、弯中、出弯、刹车、高速还是直线。",
        "observe": ["是否能稳定刹进弯", "弯中是否越推越外", "出弯能否逐步给油", "是否频繁换挡", "高速是否发飘"],
        "nextIfProblem": [
