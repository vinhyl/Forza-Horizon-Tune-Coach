        "askWhenNeeded": [
          {
            "key": "is_available",
            "prompt": "游戏里是否能安装可调差速器、可调变速箱和可调防倾杆/悬挂？",
            "requiredWhen": ["availability_unknown"],
            "choices": [
              { "value": "yes", "label": "都可以" },
              { "value": "partial", "label": "只能装一部分" },
              { "value": "no", "label": "暂时不装" }
            ]
          }
        ],
        "keepWhen": ["unlocks_tuning", "pi_delta_reasonable"],
        "skipWhen": ["pi_over_limit_and_no_symptom_to_fix"],
        "fallbackParts": ["brakes", "tire_width"],
        "handoffSymptoms": ["exit_understeer", "exit_oversteer", "frequent_shifting", "curb_bounce"],
        "sourceIds": ["sample-general-principles"],
        "confidence": "medium"
      },
      {
