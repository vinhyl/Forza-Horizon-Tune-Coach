    "upgradePlan": [
      {
        "id": "a-foundation-grip",
        "phase": "1. 基础抓地与制动",
        "candidateParts": ["tire_compound", "tire_width", "brakes"],
        "purpose": "先让原厂车具备稳定刹车、入弯和出弯基础。",
        "reason": "新手稳定向构建的第一目标不是最快直线，而是把车辆变成可预测、可重复测试。",
        "expectedBenefits": ["braking_control", "cornering_grip", "exit_traction"],
